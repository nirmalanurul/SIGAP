<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sigap.controller.BiayaTambahanController"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background-insets:0; -fx-padding:0;">

    <content>
        <VBox spacing="20">

            <padding>
                <Insets top="20" right="24" bottom="24" left="24"/>
            </padding>


            <VBox spacing="4">
                <children>
                    <Label text="Master Data  ›  Biaya Tambahan"
                           style="-fx-font-size:12px;-fx-text-fill:#888;"/>
                    <Label text="Data Biaya Tambahan"
                           style="-fx-font-size:26px;-fx-font-weight:900;-fx-text-fill:#1A2340;"/>
                    <Label text="Kelola data biaya tambahan sistem SIGAP"
                           style="-fx-font-size:13px;-fx-text-fill:#888;"/>
                </children>
            </VBox>


            <VBox spacing="16"
                  style="-fx-background-color:white;
                         -fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <children>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <children>
                            <Rectangle width="4"
                                       height="20"
                                       arcWidth="4"
                                       arcHeight="4"
                                       fill="#1A3A8F"/>

                            <Label text="Form Input Biaya Tambahan"
                                   style="-fx-font-size:15px;
                                          -fx-font-weight:700;
                                          -fx-text-fill:#1A3A8F;"/>
                        </children>
                    </HBox>

                    <GridPane hgap="30" vgap="14">

                        <columnConstraints>
                            <ColumnConstraints prefWidth="130"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints/>
                            <RowConstraints/>
                            <RowConstraints/>
                        </rowConstraints>

                        <children>



                            <Label text="ID Biaya Tambahan"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="0"/>

                            <TextField fx:id="txtBiayaTambahan"
                                       editable="false"
                                       promptText="Auto Generate"
                                       style="-fx-background-color:#F0F0F0;-fx-border-color:#D0D8E8;
                                              -fx-border-radius:6;-fx-background-radius:6;-fx-padding:6 12;
                                              -fx-font-size:13px;-fx-text-fill:#888;"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0"/>

                            <Label text="Jenis Biaya Tambahan"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1"/>

                            <ComboBox fx:id="cmbjenis"
                                      prefWidth="250"
                                      promptText="Pilih jenis biaya tambahan"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="1"/>

                            <Label text="Nominal"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="2"/>

                            <TextField fx:id="txtNominal"
                                       promptText="Masukkan Nominal"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="2"/>



                            <Label text="Keterangan"
                                   GridPane.columnIndex="2"
                                   GridPane.rowIndex="0"/>

                            <TextArea fx:id="txtKeterangan"
                                      prefRowCount="3"
                                      promptText="Masukkan Keterangan"
                                      GridPane.columnIndex="3"
                                      GridPane.rowIndex="0"
                                      GridPane.rowSpan="2"/>

                            <Label text="Status"
                                   GridPane.columnIndex="2"
                                   GridPane.rowIndex="2"/>

                            <TextField fx:id="txtstatus"
                                       editable="false"
                                       style="-fx-background-color:#F0F0F0;-fx-border-color:#D0D8E8;
                                              -fx-border-radius:6;-fx-background-radius:6;-fx-padding:6 12;
                                              -fx-font-size:13px;-fx-text-fill:#888;"
                                       GridPane.columnIndex="3"
                                       GridPane.rowIndex="2"/>

                        </children>

                    </GridPane>

                </children>

            </VBox>


            <HBox spacing="10">

                <HBox spacing="8" HBox.hgrow="ALWAYS">

                    <children>

                        <Button fx:id="btnSimpan"
                                text="SIMPAN"
                                prefWidth="130"
                                prefHeight="38"
                                onAction="#onsimpan"
                                style="-fx-background-color:#1A3A8F;
                                       -fx-text-fill:white;
                                       -fx-font-weight:700;
                                       -fx-font-size:13px;
                                       -fx-background-radius:6;
                                       -fx-padding:8 16;
                                       -fx-cursor:hand;"/>

                        <Button fx:id="btnUbah"
                                text="UBAH"
                                prefWidth="130"
                                prefHeight="38"
                                onAction="#onubah"
                                style="-fx-background-color:#D9B36C;
                                       -fx-text-fill:white;
                                       -fx-font-weight:700;
                                       -fx-font-size:13px;
                                       -fx-background-radius:6;
                                       -fx-padding:8 16;
                                       -fx-cursor:hand;"/>

                        <Button fx:id="btnHapus"
                                text="HAPUS"
                                prefWidth="130"
                                prefHeight="38"
                                onAction="#onhapus"
                                style="-fx-background-color:#E29797;
                                       -fx-text-fill:white;
                                       -fx-font-weight:700;
                                       -fx-font-size:13px;
                                       -fx-background-radius:6;
                                       -fx-padding:8 16;
                                       -fx-cursor:hand;"/>

                        <Button fx:id="btnBersih"
                                text="BATAL"
                                prefWidth="130"
                                prefHeight="38"
                                onAction="#onbersih"
                                style="-fx-background-color:#A9AEB8;
                                       -fx-text-fill:white;
                                       -fx-font-weight:700;
                                       -fx-font-size:13px;
                                       -fx-background-radius:6;
                                       -fx-padding:8 16;
                                       -fx-cursor:hand;"/>

                    </children>

                </HBox>

                <HBox spacing="8">

                    <children>

                        <TextField fx:id="txtcari"
                                   prefWidth="250"
                                   prefHeight="38"
                                   promptText="Cari ID / Jenis Biaya Tambahan / Status"/>

                        <Button text="CARI"
                                prefHeight="38"
                                onAction="#oncari"
                                style="-fx-background-color:#1A3A8F;
                                       -fx-text-fill:white;
                                       -fx-font-weight:700;
                                       -fx-font-size:13px;
                                       -fx-background-radius:6;
                                       -fx-padding:8 20;
                                       -fx-cursor:hand;"/>

                    </children>

                </HBox>

            </HBox>


            <VBox spacing="16"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white;
                         -fx-background-radius:10;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">

                <padding>
                    <Insets top="16" right="20" bottom="16" left="20"/>
                </padding>

                <children>

                    <HBox spacing="8">

                        <children>

                            <Rectangle width="4"
                                       height="20"
                                       arcWidth="4"
                                       arcHeight="4"
                                       fill="#1A3A8F"/>

                            <Label text="Daftar Biaya Tambahan"
                                   style="-fx-font-size:15px;
                                          -fx-font-weight:700;
                                          -fx-text-fill:#1A3A8F;"/>

                        </children>

                    </HBox>

                    <TableView fx:id="tabelBiayaTambahan"
                               VBox.vgrow="ALWAYS"
                               onMouseClicked="#onTableClick">

                        <columns>

                            <TableColumn fx:id="colId"
                                         text="ID Biaya Tambahan"
                                         prefWidth="140"/>

                            <TableColumn fx:id="coljenispelanggaran"
                                         text="Jenis Biaya Tambahan"
                                         prefWidth="220"/>

                            <TableColumn fx:id="colnominal"
                                         text="Nominal"
                                         prefWidth="140"/>

                            <TableColumn fx:id="colketerangan"
                                         text="Keterangan"
                                         prefWidth="260"/>

                            <TableColumn fx:id="colstatus"
                                         text="Status"
                                         prefWidth="100"/>

                        </columns>

                        <placeholder>
                            <Label text="Tidak ada data biaya tambahan."/>
                        </placeholder>

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="10">

                        <children>

                            <Label fx:id="lblTotal"
                                   text="Total Data : 0"
                                   style="-fx-font-size:13px;-fx-text-fill:#555;"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button text="«"
                                    prefWidth="36"
                                    prefHeight="34"
                                    onAction="#onFirstPage"
                                    style="-fx-background-color:white;
                                           -fx-border-color:#D0D8E8;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-text-fill:#1A3A8F;
                                           -fx-font-weight:700;
                                           -fx-cursor:hand;"/>

                            <Button text="‹"
                                    prefWidth="36"
                                    prefHeight="34"
                                    onAction="#onPrevPage"
                                    style="-fx-background-color:white;
                                           -fx-border-color:#D0D8E8;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-text-fill:#1A3A8F;
                                           -fx-font-weight:700;
                                           -fx-cursor:hand;"/>

                            <Label fx:id="lblPage"
                                   text="1"
                                   alignment="CENTER"
                                   prefWidth="36"
                                   prefHeight="34"
                                   style="-fx-background-color:#1A3A8F;
                                          -fx-text-fill:white;
                                          -fx-font-weight:700;
                                          -fx-background-radius:6;
                                          -fx-alignment:center;"/>

                            <Button text="›"
                                    prefWidth="36"
                                    prefHeight="34"
                                    onAction="#onNextPage"
                                    style="-fx-background-color:white;
                                           -fx-border-color:#D0D8E8;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-text-fill:#1A3A8F;
                                           -fx-font-weight:700;
                                           -fx-cursor:hand;"/>

                            <Button text="»"
                                    prefWidth="36"
                                    prefHeight="34"
                                    onAction="#onLastPage"
                                    style="-fx-background-color:white;
                                           -fx-border-color:#D0D8E8;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-text-fill:#1A3A8F;
                                           -fx-font-weight:700;
                                           -fx-cursor:hand;"/>

                        </children>

                    </HBox>

                </children>

            </VBox>

        </VBox>
    </content>

</ScrollPane>
