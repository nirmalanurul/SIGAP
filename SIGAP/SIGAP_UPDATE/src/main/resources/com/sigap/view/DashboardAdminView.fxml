<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="900" prefWidth="1389.0" style="-fx-background-color: #F4F6FB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sigap.controller.DashboardAdminController">

    <!-- SIDEBAR — HAK AKSES ADMIN -->
    <left>
        <AnchorPane prefWidth="220" style="-fx-background-color: #1A3A8F;" BorderPane.alignment="CENTER">
            <children>

                <!-- Header / Logo -->
                <VBox prefHeight="72" prefWidth="220" style="-fx-background-color: #152E75;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: WHITE;" text="SIGAP" />
                        <Label style="-fx-font-size: 7px; -fx-font-weight: 700; -fx-text-fill: #A0B8E8;" text="Sistem Gerai &amp; Pasar" />
                    </children>
                    <padding>
                        <Insets left="20.0" top="16.0" />
                    </padding>
                </VBox>

                <!-- Menu navigasi -->
                <VBox spacing="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="90.0">
                    <padding>
                        <Insets left="16.0" right="16.0" />
                    </padding>
                    <children>

                        <Label style="-fx-text-fill: #6080B0; -fx-font-size: 10px; -fx-font-weight: 700;" text="MENU ADMIN" />

                        <Button fx:id="btnMenuKaryawan" maxWidth="1.7976931348623157E308" onAction="#onMenuKaryawan" prefHeight="40" style="-fx-background-color: #2356C8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-background-radius: 6; -fx-cursor: hand;" text="  Karyawan" />

                        <Button fx:id="btnMenuKios" maxWidth="1.7976931348623157E308" onAction="#onMenuKios" prefHeight="40" style="-fx-background-color: transparent; -fx-text-fill: #A0C0F0; -fx-font-size: 13px; -fx-font-weight: 700; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-background-radius: 6; -fx-cursor: hand;" text="  Kios" />

                        <Button fx:id="btnMenuBiayaTambahan" maxWidth="1.7976931348623157E308" onAction="#onMenuBiayaTambahan" prefHeight="40" style="-fx-background-color: transparent; -fx-text-fill: #A0C0F0; -fx-font-size: 13px; -fx-font-weight: 700; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-background-radius: 6; -fx-cursor: hand;" text="  Biaya Tambahan" />

                    </children>
                </VBox>

                <!-- Dekorasi bawah sidebar -->
                <SVGPath content="M0,60 C60,20 130,0 220,10 L220,60 Z" fill="#F5A623" opacity="0.5" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

            </children>
        </AnchorPane>
    </left>

    <!-- AREA UTAMA -->
    <center>
        <BorderPane BorderPane.alignment="CENTER">

            <!-- Topbar -->
            <top>
                <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="16.0" style="-fx-background-color: WHITE; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);" BorderPane.alignment="CENTER">
                    <children>
                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label fx:id="lblUserName" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Nama Pengguna" />
                                <Label fx:id="lblUserRole" style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Admin" />
                            </children>
                        </VBox>
                        <Button fx:id="btnLogout" onAction="#onLogout" style="-fx-background-color: #FDEDED; -fx-text-fill: #E74C3C; -fx-font-size: 12px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14;" text="Keluar" />
                    </children>
                    <padding>
                        <Insets right="24.0" />
                    </padding>
                </HBox>
            </top>

            <!-- Content Area — modul dimuat di sini oleh DashboardAdminController -->
            <center>
                <StackPane fx:id="contentArea" BorderPane.alignment="CENTER" />
            </center>

            <!-- Footer -->
            <bottom>
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="15.0" style="-fx-background-color: WHITE; -fx-border-color: #E0E8F0 transparent transparent transparent; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="24.0" right="24.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="© 2026 SIGAP - Sistem Gerai &amp; Pasar. All rights reserved." HBox.hgrow="ALWAYS" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTanggal" style="-fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: 600;" text="27 Juni 2026" />
                        <Label fx:id="lblJam" style="-fx-font-size: 11px; -fx-text-fill: #555; -fx-font-weight: 600;" text="14:30:00" />
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Circle fill="#2ECC71" radius="5" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-weight: 600;" text="Online" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </center>

</BorderPane>