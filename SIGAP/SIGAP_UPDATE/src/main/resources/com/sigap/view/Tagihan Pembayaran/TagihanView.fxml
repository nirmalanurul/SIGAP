<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DateCell?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sigap.controller.TagihanController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
            </padding>
            <children>

                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #888;" text="Transaksi  ›  Tagihan Pembayaran Sewa" />
                        <Label style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="Data Tagihan Pembayaran Sewa" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #888;" text="Kelola tagihan pembayaran sewa kios sistem SIGAP" />
                    </children>
                </VBox>

                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                                <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Form Transaksi Tagihan Pembayaran Sewa" />
                            </children>
                        </HBox>

                        <GridPane hgap="30.0" vgap="14.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="140.0" prefWidth="140.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="200.0" />
                                <ColumnConstraints hgrow="NEVER" minWidth="140.0" prefWidth="140.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>

                                <!-- Kolom kiri -->

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="ID Tagihan"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="txtIdTagihan" editable="false"
                                           maxWidth="1.7976931348623157E308"
                                           promptText="Auto-generate"
                                           style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Karyawan"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNamaKaryawan" editable="false"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Penyewaan" />
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <TextField fx:id="txtPenyewaanTerpilih" editable="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   promptText="Belum dipilih"
                                                   style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;"
                                                   HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnPilihPenyewaan" onAction="#onPilihPenyewaan"
                                                prefHeight="32" prefWidth="90"
                                                style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-size: 12px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-border-color: #1A3A8F; -fx-border-radius: 6; -fx-cursor: hand;"
                                                text="Pilih" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Metode Bayar" />
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                    </children>
                                </HBox>
                                <ComboBox fx:id="cbMetodeBayar"
                                          maxWidth="1.7976931348623157E308"
                                          promptText="Pilih metode bayar"
                                          style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"
                                          GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Info Sewa"
                                       GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <Label fx:id="lblInfoSewa"
                                       style="-fx-font-size: 12px; -fx-text-fill: #888;"
                                       text="-"
                                       wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <!-- Kolom kanan -->

                                <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Tgl. Jatuh Tempo" />
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                    </children>
                                </HBox>
                                <DatePicker fx:id="dpTglJatuhTempo"
                                            maxWidth="1.7976931348623157E308"
                                            promptText="Pilih tanggal jatuh tempo"
                                            style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"
                                            GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Tgl. Bayar"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextField fx:id="txtTglBayar" editable="false"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;"
                                           GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Dibayar di Awal (Rp)"
                                       GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                <TextField fx:id="txtTotalDibayarAwal"
                                           maxWidth="1.7976931348623157E308"
                                           promptText="0"
                                           style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;"
                                           GridPane.columnIndex="3" GridPane.rowIndex="2" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Status"
                                       GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                <TextField fx:id="txtStatus" editable="false"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #F0F0F0; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #888;"
                                           GridPane.columnIndex="3" GridPane.rowIndex="3" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;"
                                       text="Total Tagihan (Rp)"
                                       GridPane.columnIndex="2" GridPane.rowIndex="4" />
                                <TextField fx:id="txtTotalTagihan" editable="false"
                                           maxWidth="1.7976931348623157E308"
                                           promptText="Dihitung otomatis saat disimpan"
                                           style="-fx-background-color: #F0F0F0; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #888;"
                                           GridPane.columnIndex="3" GridPane.rowIndex="4" />

                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <!-- Panel tambahan pembayaran — hanya aktif saat baris tagihan Belum Lunas/Terlambat dipilih -->
                <VBox spacing="12.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#F5A623" height="20" width="4" />
                                <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Tambah Pembayaran" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #888;" text="Sudah Dibayar (Rp):" />
                                <TextField fx:id="txtSudahDibayar" editable="false" prefWidth="150"
                                           style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" />
                                <TextField fx:id="txtNominalBayar" promptText="Nominal bayar tambahan" prefWidth="200"
                                           style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" />
                                <Button fx:id="btnBayar" onAction="#onBayar" prefHeight="34" prefWidth="110"
                                        style="-fx-background-color: #2ECC71; -fx-text-fill: WHITE; -fx-font-size: 12px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                                        text="BAYAR" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <HBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <!-- Tidak ada tombol UBAH: data inti tagihan bersifat final setelah disimpan.
                                     Aksi lanjutan yang sah hanya BAYAR (menambah Total_Dibayar) atau
                                     BATALKAN (selagi belum ada pembayaran sama sekali). -->
                                <Button fx:id="btnSimpan" onAction="#onSimpan" prefHeight="38" prefWidth="120"
                                        style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                                        text="SIMPAN" />
                                <Button fx:id="btnBatalkan" onAction="#onBatalkanTransaksi" prefHeight="38" prefWidth="150"
                                        style="-fx-background-color: #D63030; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                                        text="BATALKAN" />
                                <Button onAction="#onBersih" prefHeight="38" prefWidth="110"
                                        style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                                        text="BATAL" />
                            </children>
                        </HBox>
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="txtCari" prefHeight="38" prefWidth="260"
                                           promptText="Cari ID / Penyewaan / Status"
                                           style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-font-size: 13px;" />
                                <Button onAction="#onCari" prefHeight="38" prefWidth="94"
                                        style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                                        text="CARI" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                    </padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                                <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Daftar Tagihan Pembayaran Sewa" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelTagihan" onMouseClicked="#onTableClick"
                                   prefHeight="360"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId"           prefWidth="90"  text="ID" />
                                <TableColumn fx:id="colPenyewaan"    prefWidth="90"  text="Penyewaan" />
                                <TableColumn fx:id="colKaryawan"     prefWidth="90"  text="Karyawan" />
                                <TableColumn fx:id="colTglBayar"     prefWidth="100" text="Tgl Bayar" />
                                <TableColumn fx:id="colTglTempo"     prefWidth="100" text="Jatuh Tempo" />
                                <TableColumn fx:id="colTotalTagihan" prefWidth="110" text="Total Tagihan" />
                                <TableColumn fx:id="colTotalDibayar" prefWidth="110" text="Total Dibayar" />
                                <TableColumn fx:id="colStatus"       prefWidth="100" text="Status" />
                            </columns>
                            <placeholder>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #AAA;" text="Tidak ada data tagihan pembayaran." />
                            </placeholder>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label fx:id="lblTotal"
                                       style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: 600;"
                                       text="Total Data : 0"
                                       HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onFirstPage" prefHeight="28" prefWidth="34"
                                        style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="«" />
                                <Button onAction="#onPrevPage" prefHeight="28" prefWidth="34"
                                        style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="‹" />
                                <Label fx:id="lblPage" prefHeight="28" prefWidth="34"
                                       style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: WHITE; -fx-background-color: #1A3A8F; -fx-background-radius: 5; -fx-alignment: CENTER;"
                                       text="1" />
                                <Button onAction="#onNextPage" prefHeight="28" prefWidth="34"
                                        style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="›" />
                                <Button onAction="#onLastPage" prefHeight="28" prefWidth="34"
                                        style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="»" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
