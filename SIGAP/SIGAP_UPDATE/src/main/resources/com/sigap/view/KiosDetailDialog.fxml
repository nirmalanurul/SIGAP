<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sigap.controller.KiosDetailController"
      style="-fx-background-color: WHITE;" prefWidth="560">
    <padding>
        <Insets top="24.0" right="24.0" bottom="20.0" left="24.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                <Label fx:id="lblId" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="KS001" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblStatus" style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #1E8A3C; -fx-background-color: #E0F5E8; -fx-background-radius: 8; -fx-padding: 3 10;" text="Aktif" />
            </children>
        </HBox>

        <VBox spacing="6.0" style="-fx-padding: 16 0 12 0;">
            <children>
                <Label fx:id="lblHarga" style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #1A3A8F;" text="Rp 0" />
                <Label fx:id="lblUkuran" style="-fx-font-size: 13px; -fx-text-fill: #555;" text="0m x 0m (0 m²)" />
                <Label fx:id="lblDeskripsi" style="-fx-font-size: 13px; -fx-text-fill: #333;" wrapText="true" text="-" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 4 0 8 0;">
            <children>
                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="16" width="4" />
                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Galeri Foto Kios" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" prefHeight="360" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fx:id="vboxGaleriFoto" spacing="12.0" style="-fx-background-color: transparent; -fx-padding: 4 4 4 0;" />
            </content>
        </ScrollPane>

        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 16 0 0 0;">
            <children>
                <Button onAction="#onTutup" prefHeight="36" prefWidth="100"
                        style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="TUTUP" />
            </children>
        </HBox>

    </children>
</VBox>