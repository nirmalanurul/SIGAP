<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets:0; -fx-padding:0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sigap.controller.BiayaTambahanController">

    <content>
        <VBox spacing="20">

            <padding>
                <Insets bottom="24" left="24" right="24" top="20" />
            </padding>


            <VBox spacing="4">
                <children>
                    <Label style="-fx-font-size:12px;-fx-text-fill:#888;" text="Master Data  ›  Biaya Tambahan" />
                    <Label style="-fx-font-size:26px;-fx-font-weight:900;-fx-text-fill:#1A2340;" text="Data Biaya Tambahan" />
                    <Label style="-fx-font-size:13px;-fx-text-fill:#888;" text="Kelola data biaya tambahan sistem SIGAP" />
                </children>
            </VBox>


            <VBox spacing="16" style="-fx-background-color:white;                          -fx-background-radius:10;                          -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <children>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <children>
                            <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />

                            <Label style="-fx-font-size:15px;                                           -fx-font-weight:700;                                           -fx-text-fill:#1A3A8F;" text="Form Input Biaya Tambahan" />
                        </children>
                    </HBox>

                    <GridPane hgap="30" vgap="14">

                        <columnConstraints>
                            <ColumnConstraints prefWidth="130" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints prefWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>

                        <children>



                            <Label text="ID Biaya Tambahan" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                            <TextField fx:id="txtBiayaTambahan" editable="false" promptText="Auto Generate" style="-fx-background-color:#F0F0F0;-fx-border-color:#D0D8E8;                                               -fx-border-radius:6;-fx-background-radius:6;-fx-padding:6 12;                                               -fx-font-size:13px;-fx-text-fill:#888;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <HBox alignment="CENTER_LEFT" spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <children>
                                    <Label text="Jenis Biaya Tambahan" />
                                    <Label style="-fx-text-fill:#E23636;-fx-font-weight:900;-fx-font-size:14px;" text="*" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <children>
                                    <RadioButton fx:id="rbKerusakanFasilitas" style="-fx-font-size:13px;" text="Kerusakan Fasilitas">
                                        <toggleGroup>
                                            <ToggleGroup fx:id="tgJenis" />
                                        </toggleGroup>
                                    </RadioButton>

                                    <RadioButton fx:id="rbKeterlambatanBayarSewa" style="-fx-font-size:13px;" text="Keterlambatan Bayar Sewa" toggleGroup="$tgJenis" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <children>
                                    <Label text="Nominal" />
                                    <Label style="-fx-text-fill:#E23636;-fx-font-weight:900;-fx-font-size:14px;" text="*" />
                                </children>
                            </HBox>

                            <TextField fx:id="txtNominal" prefHeight="36.0" prefWidth="327.0" promptText="Masukkan Nominal" GridPane.columnIndex="1" GridPane.rowIndex="2" />



                            <Label text="Keterangan" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                            <TextArea fx:id="txtKeterangan" prefRowCount="3" promptText="Masukkan Keterangan" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.rowSpan="2" />

                        </children>

                    </GridPane>

                </children>

            </VBox>


            <HBox spacing="10">

                <HBox spacing="8" HBox.hgrow="ALWAYS">

                    <children>

                        <Button fx:id="btnSimpan" onAction="#onsimpan" prefHeight="38" prefWidth="130" style="-fx-background-color:#1A3A8F;                                        -fx-text-fill:white;                                        -fx-font-weight:700;                                        -fx-font-size:13px;                                        -fx-background-radius:6;                                        -fx-padding:8 16;                                        -fx-cursor:hand;" text="SIMPAN" />

                        <Button fx:id="btnUbah" onAction="#onubah" prefHeight="38" prefWidth="130" style="-fx-background-color:#D9B36C;                                        -fx-text-fill:white;                                        -fx-font-weight:700;                                        -fx-font-size:13px;                                        -fx-background-radius:6;                                        -fx-padding:8 16;                                        -fx-cursor:hand;" text="UBAH" />

                        <Button fx:id="btnHapus" onAction="#onhapus" prefHeight="38" prefWidth="130" style="-fx-background-color:#E29797;                                        -fx-text-fill:white;                                        -fx-font-weight:700;                                        -fx-font-size:13px;                                        -fx-background-radius:6;                                        -fx-padding:8 16;                                        -fx-cursor:hand;" text="HAPUS" />

                        <Button fx:id="btnBersih" onAction="#onbersih" prefHeight="38" prefWidth="130" style="-fx-background-color:#A9AEB8;                                        -fx-text-fill:white;                                        -fx-font-weight:700;                                        -fx-font-size:13px;                                        -fx-background-radius:6;                                        -fx-padding:8 16;                                        -fx-cursor:hand;" text="BATAL" />

                    </children>

                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8">

                    <children>

                        <TextField fx:id="txtcari" prefHeight="38" prefWidth="250" promptText="Cari ID / Jenis Biaya Tambahan / Status" />
         
                        <Button onAction="#oncari" prefHeight="42.0" prefWidth="107.0" style="-fx-background-color:#1A3A8F;                                        -fx-text-fill:white;                                        -fx-font-weight:700;                                        -fx-font-size:13px;                                        -fx-background-radius:6;                                        -fx-padding:8 20;                                        -fx-cursor:hand;" text="CARI" />

                        <MenuButton fx:id="btnFilter" prefHeight="38.0" prefWidth="121.0" style="-fx-background-color:#1A3A8F;                                            -fx-text-fill:white;                                            -fx-font-weight:700;                                            -fx-font-size:13px;                                            -fx-background-radius:6;                                            -fx-mark-color:white;                                            -fx-padding:8 20;                                            -fx-cursor:hand;">
                            <items>

                                <Menu text="Urutkan Nama">
                                    <items>
                                        <RadioMenuItem fx:id="rmiNamaAZ" onAction="#onFilterNamaAZ" text="A - Z">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="tgFilterNama" />
                                            </toggleGroup>
                                        </RadioMenuItem>
                                        <RadioMenuItem fx:id="rmiNamaZA" onAction="#onFilterNamaZA" text="Z - A" toggleGroup="$tgFilterNama" />
                                    </items>
                                </Menu>

                                <Menu text="Urutkan Harga">
                                    <items>
                                        <RadioMenuItem fx:id="rmiHargaTermahal" onAction="#onFilterHargaTermahal" text="Termahal - Termurah">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="tgFilterHarga" />
                                            </toggleGroup>
                                        </RadioMenuItem>
                                        <RadioMenuItem fx:id="rmiHargaTermurah" onAction="#onFilterHargaTermurah" text="Termurah - Termahal" toggleGroup="$tgFilterHarga" />
                                    </items>
                                </Menu>

                                <Menu text="Jenis">
                                    <items>
                                        <RadioMenuItem fx:id="rmiJenisKerusakan" onAction="#onFilterJenisKerusakan" text="Kerusakan Fasilitas">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="tgFilterJenis" />
                                            </toggleGroup>
                                        </RadioMenuItem>
                                        <RadioMenuItem fx:id="rmiJenisTerlambat" onAction="#onFilterJenisTerlambat" text="Keterlambatan Bayar Sewa" toggleGroup="$tgFilterJenis" />
                                    </items>
                                </Menu>

                                <Menu text="Status">
                                    <items>
                                        <RadioMenuItem fx:id="rmiStatusAktif" onAction="#onFilterStatusAktif" text="Aktif">
                                            <toggleGroup>
                                                <ToggleGroup fx:id="tgFilterStatus" />
                                            </toggleGroup>
                                        </RadioMenuItem>
                                        <RadioMenuItem fx:id="rmiStatusTidakAktif" onAction="#onFilterStatusTidakAktif" text="Tidak Aktif" toggleGroup="$tgFilterStatus" />
                                    </items>
                                </Menu>

                                <SeparatorMenuItem />

                                <MenuItem fx:id="miResetFilter" onAction="#onResetFilter" text="Reset Filter" />

                            </items>
                     <graphic>
                        <Label text="FILTER" textFill="WHITE" />
                     </graphic>
                        </MenuButton>


                    </children>

                </HBox>

            </HBox>


            <VBox spacing="16" style="-fx-background-color:white;                          -fx-background-radius:10;                          -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);" VBox.vgrow="ALWAYS">

                <padding>
                    <Insets bottom="16" left="20" right="20" top="16" />
                </padding>

                <children>

                    <HBox spacing="8">

                        <children>

                            <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />

                            <Label style="-fx-font-size:15px;                                           -fx-font-weight:700;                                           -fx-text-fill:#1A3A8F;" text="Daftar Biaya Tambahan" />

                        </children>

                    </HBox>

                    <TableView fx:id="tabelBiayaTambahan" onMouseClicked="#onTableClick" VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn fx:id="colId" prefWidth="140" text="ID Biaya Tambahan" />

                            <TableColumn fx:id="coljenispelanggaran" prefWidth="220" text="Jenis Biaya Tambahan" />

                            <TableColumn fx:id="colnominal" prefWidth="140" text="Nominal" />

                            <TableColumn fx:id="colketerangan" prefWidth="260" text="Keterangan" />

                            <TableColumn fx:id="colstatus" prefWidth="100" text="Status" />

                        </columns>

                        <placeholder>
                            <Label text="Tidak ada data biaya tambahan." />
                        </placeholder>

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>

                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="10">

                        <children>

                            <Label fx:id="lblTotal" style="-fx-font-size:13px;-fx-text-fill:#555;" text="Total Data : 0" />

                            <Region HBox.hgrow="ALWAYS" />

                            <Button onAction="#onFirstPage" prefHeight="34" prefWidth="36" style="-fx-background-color:white;                                            -fx-border-color:#D0D8E8;                                            -fx-border-radius:6;                                            -fx-background-radius:6;                                            -fx-text-fill:#1A3A8F;                                            -fx-font-weight:700;                                            -fx-cursor:hand;" text="«" />

                            <Button onAction="#onPrevPage" prefHeight="34" prefWidth="36" style="-fx-background-color:white;                                            -fx-border-color:#D0D8E8;                                            -fx-border-radius:6;                                            -fx-background-radius:6;                                            -fx-text-fill:#1A3A8F;                                            -fx-font-weight:700;                                            -fx-cursor:hand;" text="‹" />

                            <Label fx:id="lblPage" alignment="CENTER" prefHeight="34" prefWidth="36" style="-fx-background-color:#1A3A8F;                                           -fx-text-fill:white;                                           -fx-font-weight:700;                                           -fx-background-radius:6;                                           -fx-alignment:center;" text="1" />

                            <Button onAction="#onNextPage" prefHeight="34" prefWidth="36" style="-fx-background-color:white;                                            -fx-border-color:#D0D8E8;                                            -fx-border-radius:6;                                            -fx-background-radius:6;                                            -fx-text-fill:#1A3A8F;                                            -fx-font-weight:700;                                            -fx-cursor:hand;" text="›" />

                            <Button onAction="#onLastPage" prefHeight="34" prefWidth="36" style="-fx-background-color:white;                                            -fx-border-color:#D0D8E8;                                            -fx-border-radius:6;                                            -fx-background-radius:6;                                            -fx-text-fill:#1A3A8F;                                            -fx-font-weight:700;                                            -fx-cursor:hand;" text="»" />

                        </children>

                    </HBox>

                </children>

            </VBox>

        </VBox>
    </content>

</ScrollPane>
