<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true" prefHeight="729.0" prefWidth="939.0" style="-fx-background-color: transparent; -fx-background-insets: 0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sigap.controller.KiosController">
    <content>
        <VBox prefWidth="900.0" spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="28.0" right="28.0" top="22.0" />
            </padding>
            <children>
                <VBox spacing="3.0">
                    <children>
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #8898AA;" text="Master Data  ›  Kios" />
                        <Label style="-fx-font-size: 25px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="Data Kios" />
                    </children>
                </VBox>

                <VBox spacing="14.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="22.0" left="22.0" right="22.0" top="18.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4.0" arcWidth="4.0" fill="#1A3A8F" height="20.0" width="4.0" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Form Input Kios" />
                            </children>
                        </HBox>

                        <GridPane hgap="24.0" vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="120.0" prefWidth="125.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="160.0" prefWidth="200.0" />
                                <ColumnConstraints hgrow="NEVER" minWidth="120.0" prefWidth="125.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="160.0" prefWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="36.0" prefHeight="36.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="36.0" prefHeight="36.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="36.0" prefHeight="36.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="36.0" prefHeight="36.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="36.0" prefHeight="36.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="ID Kios" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="txtIdKios" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-generate" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Harga Kios (Rp)" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtHarga" maxWidth="1.7976931348623157E308" promptText="Contoh: 500000" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Panjang (m)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <TextField fx:id="txtPanjang" maxWidth="1.7976931348623157E308" promptText="Contoh: 4.50" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Lebar (m)" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <TextField fx:id="txtLebar" maxWidth="1.7976931348623157E308" promptText="Contoh: 3.00" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Luas (m²)" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextField fx:id="txtLuas" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-kalkulasi" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Deskripsi" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextArea fx:id="txtDeskripsi" maxWidth="1.7976931348623157E308" prefHeight="80.0" promptText="Deskripsi kios (opsional)" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="1" GridPane.rowSpan="2" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Ketersediaan" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                <TextField fx:id="txtStsKetersediaan" editable="false" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #555;" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Status Kios" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <TextField fx:id="txtStsKios" editable="false" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #555;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <HBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button mnemonicParsing="false" onAction="#onTambah" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="TAMBAH" />
                                <Button fx:id="btnSimpan" mnemonicParsing="false" onAction="#onSimpan" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="SIMPAN" />
                                <Button fx:id="btnUbah" mnemonicParsing="false" onAction="#onUbah" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #E8A020; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="UBAH" />
                                <Button fx:id="btnHapus" mnemonicParsing="false" onAction="#onHapus" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #D63030; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="HAPUS" />
                                <Button mnemonicParsing="false" onAction="#onBersih" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="BATAL" />
                            </children>
                        </HBox>
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="txtCari" prefHeight="36.0" prefWidth="230.0" promptText="Cari ID / Deskripsi / Status..." style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" />
                                <Button mnemonicParsing="false" onAction="#onCari" prefHeight="36.0" prefWidth="80.0" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="CARI" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="12.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="16.0" left="22.0" right="22.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4.0" arcWidth="4.0" fill="#1A3A8F" height="20.0" width="4.0" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Daftar Kios" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelKios" onMouseClicked="#onTableClick" prefHeight="320.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="75.0" text="ID Kios" />
                                <TableColumn fx:id="colHarga" prefWidth="130.0" text="Harga" />
                                <TableColumn fx:id="colPanjang" prefWidth="85.0" text="Panjang" />
                                <TableColumn fx:id="colLebar" prefWidth="85.0" text="Lebar" />
                                <TableColumn fx:id="colLuas" prefWidth="85.0" text="Luas" />
                                <TableColumn fx:id="colDeskripsi" prefWidth="190.0" text="Deskripsi" />
                                <TableColumn fx:id="colStsKetersediaan" prefWidth="120.0" text="Ketersediaan" />
                                <TableColumn fx:id="colStsKios" prefWidth="85.0" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <placeholder>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #AAA;" text="Tidak ada data kios." />
                            </placeholder>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="lblTotal" style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: 600;" text="Total Data : 0" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#onFirstPage" prefHeight="28.0" prefWidth="32.0" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="«" />
                                <Button mnemonicParsing="false" onAction="#onPrevPage" prefHeight="28.0" prefWidth="32.0" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="‹" />
                                <Label fx:id="lblPage" alignment="CENTER" prefHeight="28.0" prefWidth="32.0" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: WHITE; -fx-background-color: #1A3A8F; -fx-background-radius: 5;" text="1" />
                                <Button mnemonicParsing="false" onAction="#onNextPage" prefHeight="28.0" prefWidth="32.0" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="›" />
                                <Button mnemonicParsing="false" onAction="#onLastPage" prefHeight="28.0" prefWidth="32.0" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="»" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
