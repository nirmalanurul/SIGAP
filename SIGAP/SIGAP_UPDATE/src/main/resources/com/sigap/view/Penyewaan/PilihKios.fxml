<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16.0" style="-fx-background-color: #F4F6FB;"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sigap.controller.PilihKiosController"
      prefWidth="620" prefHeight="500">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <VBox spacing="4.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <children>
                        <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                        <Label style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="Pilih Kios" />
                    </children>
                </HBox>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #888;" text="Klik salah satu baris untuk memilih kios" />
            </children>
        </VBox>

        <HBox spacing="8.0">
            <children>
                <TextField fx:id="txtCari" promptText="Cari ID / Deskripsi"
                           prefHeight="36" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-font-size: 13px;" />
                <Button onAction="#onCari" prefHeight="36" prefWidth="90"
                        style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="CARI" />
            </children>
        </HBox>

        <TableView fx:id="tabelKios" onMouseClicked="#onRowClicked"
                   prefHeight="360"
                   style="-fx-background-color: WHITE; -fx-background-radius: 8;"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"        prefWidth="80"  text="ID" />
                <TableColumn fx:id="colHarga"     prefWidth="120" text="Harga (Rp)" />
                <TableColumn fx:id="colUkuran"    prefWidth="100" text="Ukuran (m)" />
                <TableColumn fx:id="colLuas"      prefWidth="90"  text="Luas (m²)" />
                <TableColumn fx:id="colDeskripsi" prefWidth="140" text="Deskripsi" />
            </columns>
            <placeholder>
                <Label style="-fx-font-size: 13px; -fx-text-fill: #AAA;" text="Tidak ada data kios aktif." />
            </placeholder>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#onBatal" prefHeight="36" prefWidth="100"
                        style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="BATAL" />
            </children>
        </HBox>

    </children>
</VBox>
