<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sigap.controller.KiosController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
            </padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #888;" text="Master Data  ›  Kios" />
                        <Label text="Data Kios" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #888;" />
                    </children>
                </VBox>

                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                                <Label text="Form Input Kios" style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" />
                            </children>
                        </HBox>

                        <GridPane hgap="30.0" vgap="14.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="130.0" prefWidth="130.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                                <ColumnConstraints hgrow="NEVER" prefWidth="130.0" minWidth="130.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints vgrow="SOMETIMES" minHeight="34.0" prefHeight="34.0" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="ID Kios" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" />
                                <TextField fx:id="txtIdKios" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-generate" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Harga Kios (Rp)" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtHarga" maxWidth="1.7976931348623157E308" promptText="Contoh: 500000" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Panjang (m)" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" />
                                <TextField fx:id="txtPanjang" promptText="Contoh: 4.50" maxWidth="1.7976931348623157E308" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Lebar (m)" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <TextField fx:id="txtLebar" maxWidth="1.7976931348623157E308" promptText="Contoh: 3.00" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Luas (m²)" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" />
                                <TextField fx:id="txtLuas" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-kalkulasi" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label GridPane.columnIndex="2" GridPane.rowIndex="1" text="Deskripsi" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" />
                                <TextArea fx:id="txtDeskripsi" maxWidth="1.7976931348623157E308" promptText="Deskripsi kios (opsional)" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="1" GridPane.rowSpan="2" />

                                <Label text="Sts. Ketersediaan" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                <TextField fx:id="txtStsKetersediaan" editable="false" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #555;" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                                <Label text="Status Kios" prefWidth="130" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <TextField fx:id="txtStsKios" editable="false" prefWidth="200" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px; -fx-text-fill: #555;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_LEFT" spacing="16.0" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <HBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button text="TAMBAH" onAction="#onTambah" prefHeight="38" prefWidth="120" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button fx:id="btnSimpan" text="SIMPAN" onAction="#onSimpan" prefHeight="38" prefWidth="120" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button fx:id="btnUbah" onAction="#onUbah" text="UBAH" prefWidth="110" prefHeight="38" style="-fx-background-color: #E8A020; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button fx:id="btnHapus" onAction="#onHapus" prefHeight="38" prefWidth="130" text="HAPUS" style="-fx-background-color: #D63030; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button onAction="#onBersih" prefHeight="38" prefWidth="110" text="BATAL" style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="txtCari" prefHeight="38" prefWidth="240" promptText="Cari ID / Deskripsi / Status..." style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-font-size: 13px;" />
                                <Button onAction="#onCari" prefHeight="38" prefWidth="94" text="CARI" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                            <children>
                                <Rectangle fill="#1A3A8F" height="20" width="4" arcHeight="4" arcWidth="4" />
                                <Label text="Daftar Kios" style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelKios" onMouseClicked="#onTableClick" prefHeight="320" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colId" text="ID Kios" prefWidth="80" />
                                <TableColumn fx:id="colHarga" prefWidth="130" text="Harga" />
                                <TableColumn fx:id="colPanjang" text="Panjang" prefWidth="90" />
                                <TableColumn fx:id="colLebar" prefWidth="90" text="Lebar" />
                                <TableColumn fx:id="colLuas" text="Luas" prefWidth="90" />
                                <TableColumn fx:id="colDeskripsi" prefWidth="200" text="Deskripsi" />
                                <TableColumn fx:id="colStsKetersediaan" text="Ketersediaan" prefWidth="130" />
                                <TableColumn fx:id="colStsKios" prefWidth="90" text="Status" />
                            </columns>
                            <placeholder>
                                <Label text="Tidak ada data kios." style="-fx-font-size: 13px; -fx-text-fill: #AAA;" />
                            </placeholder>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label fx:id="lblTotal" text="Total Data : 0" style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: 600;" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onFirstPage" prefHeight="28" prefWidth="34" text="«" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" />
                                <Button onAction="#onPrevPage" text="‹" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" />
                                <Label fx:id="lblPage" text="1" prefHeight="28" prefWidth="34" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: WHITE; -fx-background-color: #1A3A8F; -fx-background-radius: 5; -fx-alignment: CENTER;" />
                                <Button onAction="#onNextPage" prefHeight="28" prefWidth="34" text="›" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" />
                                <Button text="»" onAction="#onLastPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
