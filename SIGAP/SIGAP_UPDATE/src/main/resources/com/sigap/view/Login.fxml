        <!-- ===================== LOGIN CARD ===================== -->
        <!-- AnchorPane bebas dari auto-layout: semua child pakai layoutX/layoutY,
             jadi tinggal di-drag langsung di Scene Builder sesuka hati -->
        <AnchorPane fx:id="loginCard" maxHeight="560.0" maxWidth="420.0" prefHeight="560.0" prefWidth="420.0" style="-fx-background-color: white; -fx-background-radius: 26;">
            <effect>
                <DropShadow blurType="GAUSSIAN" color="#1A3A8F33" height="60.0" offsetY="14.0" radius="28.0" width="60.0" />
            </effect>
            <children>

                <!-- Logo badge -->
                <StackPane layoutX="174.0" layoutY="40.0" prefHeight="72.0" prefWidth="72.0">
                    <children>
                        <Circle fill="#1A3A8F" radius="36.0">
                            <effect>
                                <DropShadow blurType="GAUSSIAN" color="#1A3A8F55" offsetY="6.0" radius="16.0" />
                            </effect>
                        </Circle>
                    </children>
                </StackPane>

                <Label alignment="CENTER" layoutX="46.0" layoutY="122.0" prefWidth="328.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A3A8F;" text="Selamat Datang" />

                <Label alignment="CENTER" layoutX="46.0" layoutY="156.0" prefWidth="328.0" style="-fx-font-size: 13px; -fx-text-fill: #8792AC;" text="Masuk untuk melanjutkan ke akun Anda" />

                <!-- Username -->
                <Label layoutX="46.0" layoutY="196.0" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A5578;" text="USERNAME" />
                <TextField fx:id="usernameField" layoutX="46.0" layoutY="214.0" prefHeight="44.0" prefWidth="328.0" promptText="Masukkan username" style="-fx-background-color: #F5F7FC; -fx-background-radius: 12; -fx-border-color: #E3E8F5; -fx-border-radius: 12; -fx-border-width: 1.2; -fx-font-size: 13px; -fx-prompt-text-fill: #A9B1C9;">
                    <padding>
                        <Insets left="14.0" right="14.0" />
                    </padding>
                </TextField>

                <!-- Password -->
                <Label layoutX="46.0" layoutY="272.0" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A5578;" text="PASSWORD" />
                <PasswordField fx:id="passwordField" layoutX="46.0" layoutY="290.0" prefHeight="44.0" prefWidth="328.0" promptText="Masukkan password" style="-fx-background-color: #F5F7FC; -fx-background-radius: 12; -fx-border-color: #E3E8F5; -fx-border-radius: 12; -fx-border-width: 1.2; -fx-font-size: 13px; -fx-prompt-text-fill: #A9B1C9;">
                    <padding>
                        <Insets left="14.0" right="14.0" />
                    </padding>
                </PasswordField>

                <!-- Error message -->
                <Label fx:id="errorLabel" layoutX="46.0" layoutY="374.0" managed="false" prefWidth="328.0" style="-fx-font-size: 12px; -fx-text-fill: #E85252;" text="Username atau password salah" visible="false" wrapText="true" />

                <!-- Login button -->
                <Button fx:id="loginButton" defaultButton="true" layoutX="46.0" layoutY="374.0" mnemonicParsing="false" prefHeight="46.0" prefWidth="328.0" style="-fx-background-color: linear-gradient(to right, #1A3A8F, #3A7BD5); -fx-background-radius: 12; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Masuk">
                    <effect>
