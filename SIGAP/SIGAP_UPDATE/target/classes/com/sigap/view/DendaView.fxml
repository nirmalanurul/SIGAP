<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sigap.controller.DendaController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
            </padding>
            <children>

                <!-- Breadcrumb + judul -->
                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #888;" text="Master Data  ›  Denda" />
                        <Label style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="Data Denda" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #888;" />
                    </children>
                </VBox>

                <!-- Form Input -->
                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                                <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Form Input Denda" />
                            </children>
                        </HBox>

                        <GridPane hgap="30.0" vgap="14.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="110.0" prefWidth="110.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                <ColumnConstraints hgrow="NEVER" minWidth="110.0" prefWidth="110.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label fx:id="iddenda" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="ID Denda" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="txtIdDenda" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-generate" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label fx:id="jenispelanggaran" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Jenis Pelanggaran" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtJenisPelannggaran" maxWidth="1.7976931348623157E308" prefHeight="33.0" prefWidth="237.0" promptText="Masukkan jenis pelanggaran" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label fx:id="nominaldenda" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Nominal Denda" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <TextField fx:id="txtNominalDenda" maxWidth="1.7976931348623157E308" promptText="Masukkan nominal denda" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label fx:id="keterangan" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Keterangan" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextArea fx:id="txtKeterangan" maxWidth="1.7976931348623157E308" promptText="Masukkan keterangan denda" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.rowSpan="2" />

                                <Label fx:id="status" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Status" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <TextField fx:id="txtstatus" prefHeight="26.0" prefWidth="485.0" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <!-- Tombol aksi + pencarian -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <HBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button onAction="#ontambah" prefHeight="38" prefWidth="120" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="TAMBAH" />
                                <Button fx:id="btnSimpan" onAction="#onsimpan" prefHeight="38" prefWidth="120" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="SIMPAN" />
                                <Button fx:id="btnUbah" onAction="#onubah" prefHeight="38" prefWidth="110" style="-fx-background-color: #E8A020; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="UBAH" />
                                <Button fx:id="btnHapus" onAction="#onhapus" prefHeight="38" prefWidth="130" style="-fx-background-color: #D63030; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="HAPUS" />
                                <Button fx:id="btnBersih" onAction="#onbersih" prefHeight="38" prefWidth="110" style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="BATAL" />
                            </children>
                        </HBox>
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="txtcari" prefHeight="38" prefWidth="240" promptText="Cari ID / Jenis Pelanggaran / Status" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-font-size: 13px;" />
                                <Button onAction="#oncari" prefHeight="38" prefWidth="94" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="CARI" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Tabel -->
                <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                    <padding>
                        <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                                <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Daftar Penyewa" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelDenda" onMouseClicked="#onTableClick" prefHeight="320" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="100" text="ID Denda" />
                                <TableColumn fx:id="coljenispelanggaran" prefWidth="170" text="Jenis Pelanggaran" />
                                <TableColumn fx:id="colnominal" prefWidth="243.0" text="Nominal Denda" />
                                <TableColumn fx:id="colketerangan" prefWidth="363.0" text="Keterangan" />
                                <TableColumn fx:id="colstatus" prefWidth="96.0" text="Status" />
                            </columns>
                            <placeholder>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #AAA;" text="Tidak ada data denda." />
                            </placeholder>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- Pagination -->
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label fx:id="lblTotal" style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: 600;" text="Total Data : 0" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onFirstPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="«" />
                                <Button onAction="#onPrevPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="‹" />
                                <Label fx:id="lblPage" prefHeight="28" prefWidth="34" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: WHITE; -fx-background-color: #1A3A8F; -fx-background-radius: 5; -fx-alignment: CENTER;" text="1" />
                                <Button onAction="#onNextPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="›" />
                                <Button onAction="#onLastPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="»" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
